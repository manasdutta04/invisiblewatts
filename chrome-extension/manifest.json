{
  "manifest_version": 3,
  "name": "InvisibleWatts",
  "description": "Track the hidden carbon cost of your digital activity. See CO₂ and estimated energy cost in ₹ per site, per minute.",
  "version": "1.1.0",

  "action": {
    "default_popup": "popup.html",
    "default_title": "InvisibleWatts — Carbon Meter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "idle"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
